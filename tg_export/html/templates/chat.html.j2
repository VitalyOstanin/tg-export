{% extends "base.html.j2" %}
{% from "message.html.j2" import render_message_block, render_album_block %}
{% from "service_message.html.j2" import render_service %}
{% block content %}
<div class="page-header">
  <h1>{{ chat_name }}</h1>
  <div class="meta">{{ chat_type }}{% if chat_members %} | {{ chat_members }} members{% endif %}</div>
</div>

<div class="nav">
  <a href="{{ index_href }}">Index</a>
  {% if prev_href %}<a href="{{ prev_href }}">Previous</a>{% endif %}
  <span class="current">{{ page_label }}</span>
  {% if next_href %}<a href="{{ next_href }}">Next</a>{% endif %}
</div>

{% if pages_info|length > 1 %}
<details class="toc">
  <summary>Months ({{ pages_info|length }})</summary>
  <ul>
    {% for p in pages_info %}
    <li>{% if p.filename == current_page %}<strong>{{ p.label }}</strong>{% else %}<a href="{{ p.filename }}">{{ p.label }}</a>{% endif %}</li>
    {% endfor %}
  </ul>
</details>
{% endif %}

{% for item in items %}
{% if item.type == "date_separator" %}
<div class="date-separator"><span>{{ item.date }}</span></div>
{% elif item.type == "service" %}
{{ render_service(item.msg) }}
{% elif item.type == "album" %}
{{ render_album_block(item) }}
{% else %}
{{ render_message_block(item) }}
{% endif %}
{% endfor %}

<div class="nav bottom-nav">
  <a href="{{ index_href }}">Index</a>
  {% if prev_href %}<a href="{{ prev_href }}">Previous</a>{% endif %}
  <span class="current">{{ page_label }}</span>
  {% if next_href %}<a href="{{ next_href }}">Next</a>{% endif %}
</div>

{% if pages_info|length > 1 %}
<div class="pagination">
  {% for p in pages_info %}
    {% if p.filename == current_page %}
      <span class="current">{{ p.label }}</span>
    {% else %}
      <a href="{{ p.filename }}">{{ p.label }}</a>
    {% endif %}
  {% endfor %}
</div>
{% endif %}
{% endblock %}
